# ============================================
# ENVIRONMENT VARIABLES - Backend NestJS
# ============================================
# Copiez ce fichier en .env et remplissez les valeurs

# ============================================
# APPLICATION
# ============================================
NODE_ENV=development
PORT=3001

# ============================================
# CORS - URL du frontend autorisée
# ============================================
# Séparez plusieurs origines par des virgules si nécessaire.
CORS_ORIGIN=http://localhost:5173

# ============================================
# SUPABASE
# ============================================
SUPABASE_URL=https://sxdofugjiqjlfuklfwjd.supabase.co
SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ============================================
# STORAGE
# ============================================
STORAGE_BUCKET_DOCUMENTS=documents
STORAGE_BUCKET_PUBLIC_IMAGES=public-images

# ============================================
# SUPERADMIN RACINE
# ============================================

# Seul cet email peut inviter d'autres superadmins.
SUPERADMIN_ROOT_EMAIL=

# ============================================
# STRIPE (Paiements)
# ============================================
STRIPE_ENABLED=true
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
STRIPE_SUBSCRIPTION_WEBHOOK_SECRET=whsec_your_subscription_webhook_secret



# ============================================
# RESEND (Envoi d'emails)
# ============================================
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=facturation@votre-domaine.com

# ============================================
# FRONTEND URL (pour les liens dans les emails)
# ============================================
FRONTEND_URL=http://localhost:5173



# ============================================
# PUPPETEER (PDF generation)
# ============================================
# PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium
# Laisser vide pour utiliser le browser bundled de Puppeteer (recommandé en local).
# Définir à /usr/bin/chromium dans Docker/Railway où Chromium système est installé.

# ============================================
# RECHERCHE SIREN / SIRET
# ============================================
# gouv = API publique recherche-entreprises.api.gouv.fr (défaut, sans clé)
# insee = API Sirene INSEE (nécessite INSEE_SIRENE_API_KEY)
SIREN_PROVIDER=gouv
# INSEE_SIRENE_API_KEY=
# Optionnel — défaut https://api.insee.fr/api-sirene/3.11
# INSEE_SIRENE_BASE_URL=https://api.insee.fr/api-sirene/3.11
# Optionnel — défaut X-INSEE-Api-Key-Integration (spec OpenAPI 3.11)
# INSEE_SIRENE_API_KEY_HEADER=X-INSEE-Api-Key-Integration

# ============================================
# CHORUS PRO / PISTE (Facturation électronique)
# ============================================
# CHORUS_PRO_ENV=sandbox
# PISTE_CLIENT_ID=
# PISTE_CLIENT_SECRET=
# CHORUS_CREDENTIALS_ENCRYPTION_KEY=
